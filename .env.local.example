# ============================================================
# Kendallville Daily — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (for donation button)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_DONATION_PRICE_ID=price_...   # Create a "custom amount" product in Stripe

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-...

# Cron Security (random secret you generate — used to protect the pipeline endpoint)
CRON_SECRET=your-random-secret-here

# Site Config
NEXT_PUBLIC_SITE_URL=https://kendallvilledaily.com
NEXT_PUBLIC_SITE_NAME=Kendallville Daily

# Google Search Console verification (add meta tag from GSC)
NEXT_PUBLIC_GOOGLE_VERIFICATION=...
